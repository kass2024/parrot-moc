# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here

# Main database
DB_HOST=localhost
DB_NAME=iotxa_db
DB_USER=your_db_user
DB_PASS=your_db_password
DB_CHARSET=utf8mb4

# Register module database
REGISTER_DB_HOST=localhost
REGISTER_DB_NAME=interview
REGISTER_DB_USER=root
REGISTER_DB_PASS=
REGISTER_DB_CHARSET=utf8mb4

# SMTP
SMTP_HOST=your-smtp-host.example.com
SMTP_PORT=465
SMTP_USER=your-smtp-user@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=your-smtp-user@example.com
SMTP_FROM_NAME=Parrot License System

# Admin panel (username:password, comma-separated)
ADMIN_USERS=admin:change-me
